{
  "name": "oneway-http",
  "version": "0.1.0",
  "description": "Runtime-aware HTTP client scaffold for Node.js and browser consumers.",
  "type": "module",
  "author": "Seth Livingston",
  "license": "ISC",
  "homepage": "https://github.com/sethlivingston/oneway-http#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethlivingston/oneway-http.git"
  },
  "bugs": {
    "url": "https://github.com/sethlivingston/oneway-http/issues"
  },
  "keywords": [
    "http",
    "typescript",
    "esm",
    "browser",
    "node"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs').then((fs) => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsup --config tsup.config.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "pretest:node": "npm run build",
    "test:node": "vitest run --project node",
    "pretest:browser": "npm run build",
    "test:browser": "vitest run --project chromium --project firefox --project webkit",
    "test:browser:install": "playwright install chromium firefox webkit",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.59.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
