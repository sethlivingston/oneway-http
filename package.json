{
  "name": "@sethlivingston/oneway-http",
  "version": "0.1.5",
  "description": "A full-ass HTTP client for Node.js and browsers.",
  "type": "module",
  "author": "Seth Livingston",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/sethlivingston/oneway-http#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethlivingston/oneway-http.git"
  },
  "bugs": {
    "url": "https://github.com/sethlivingston/oneway-http/issues"
  },
  "keywords": [
    "http",
    "typescript",
    "esm",
    "browser",
    "node"
  ],
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs').then((fs) => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsup --config tsup.config.ts",
    "lint": "eslint src tests tsup.config.ts vitest.config.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "pretest:node": "npm run build",
    "test:node": "vitest run --project node",
    "pretest:chromium": "npm run build",
    "test:chromium": "vitest run --project chromium",
    "pretest:firefox": "npm run build",
    "test:firefox": "vitest run --project firefox",
    "pretest:webkit": "npm run build",
    "test:webkit": "vitest run --project webkit",
    "pretest:browser": "npm run build",
    "test:browser": "vitest run --project chromium --project firefox --project webkit",
    "test:browser:install": "playwright install chromium firefox webkit",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@sethlivingston/eslint-plugin-typescript-narrows": "^1.1.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "playwright": "^1.59.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
